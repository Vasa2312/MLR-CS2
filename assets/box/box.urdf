<?xml version="1.0" ?>
<robot name="cube">
  <link name="base_link">
    <inertial>
      <origin rpy="0 0 0" xyz="0 0 0"/>
       <mass value="0.1"/>
       <!-- 1/6ma^2 -->
       <inertia ixx="1e-3" ixy="0.0" ixz="0.0" iyy="1e-3" iyz="0.0" izz="1e-3" />
    </inertial>
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
				<box size="0.1 0.1 0.1"/>
      </geometry>
       <material name="red">
        <color rgba="0.7 0 0 1"/>
      </material>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
	 	    <box size="0.1 0.1 0.1"/>
      </geometry>
    </collision>
  </link>
</robot>
